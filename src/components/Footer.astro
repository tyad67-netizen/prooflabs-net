---
const currentYear = new Date().getFullYear();

const footerLinks = {
  'Explore': [
    { label: 'Strategies', href: '/strategies' },
    { label: 'Credit Cards', href: '/best-credit-cards' },
    { label: 'Savings', href: '/banking/high-yield-savings' },
    { label: 'Cash Back Cards', href: '/categories/cash-back' },
  ],
  'Resources': [
    { label: 'Methodology', href: '/methodology' },
    { label: 'About Tyler', href: '/about' },
    { label: 'Contact', href: '/contact' },
  ],
  'Legal': [
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Terms of Service', href: '/terms' },
    { label: 'Affiliate Disclosure', href: '/disclosure' },
    { label: 'How We Make Money', href: '/how-we-make-money' },
  ],
};
---

<footer class="bg-gray-900 text-gray-300 mt-20">
  <div class="container-custom py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1">
        <img src="/logo-icon.png" alt="ProofLabs" style="height: 40px; margin-bottom: 1rem;" />
        <p class="text-sm text-gray-400 mb-4">
          Maximize every dollar you spend. Real strategies, real numbers, real results.
        </p>
        <!-- Twitter/X Link -->
        <a href="https://x.com/TheProofLabs" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 0.75rem; color: #d1d5db; font-size: 1rem; text-decoration: none; transition: color 0.2s; padding: 0.5rem 0;" onmouseover="this.style.color='#ffffff';" onmouseout="this.style.color='#d1d5db';">
          <svg style="width: 1.5rem; height: 1.5rem;" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span style="font-weight: 600;">Follow on X</span>
        </a>
        <p class="text-xs text-gray-500" style="margin-top: 1rem;">
          &copy; {currentYear} ProofLabs. All recommendations based on independent analysis.
        </p>
      </div>

      <!-- Link Columns -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h4 class="font-semibold text-white mb-4">{category}</h4>
          <ul class="space-y-2">
            {links.map(link => (
              <li>
                <a href={link.href} class="text-sm hover:text-primary-400 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Disclosure -->
    <div class="mt-12 pt-8 border-t border-gray-800">
      <div style="background: rgba(255,255,255,0.05); border-radius: var(--radius-md); padding: 1.5rem; border: 1px solid rgba(255,255,255,0.1);">
        <div style="display: flex; align-items: flex-start; gap: 1rem;">
          <svg style="width: 1.5rem; height: 1.5rem; color: #60a5fa; flex-shrink: 0; margin-top: 0.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <p style="font-size: 0.875rem; color: #d1d5db; line-height: 1.6;">
              <strong style="color: #e5e7eb;">Affiliate Disclosure:</strong> ProofLabs may earn a commission when you sign up for products through links on this site. This includes credit cards, savings accounts, investing platforms, and cashback services. Our rankings are based on real usage and math, not commissions. See our <a href="/how-we-make-money" style="color: #60a5fa; text-decoration: underline;">full explanation</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

---
const currentYear = new Date().getFullYear();

const footerLinks = {
  'Credit Cards': [
    { label: 'Best Cash Back Cards', href: '/categories/cash-back' },
    { label: 'Best Travel Cards', href: '/categories/travel' },
    { label: 'Best Balance Transfer', href: '/categories/balance-transfer' },
    { label: 'All Reviews', href: '/reviews' },
  ],
  'Resources': [
    { label: 'Methodology', href: '/methodology' },
    { label: 'About Us', href: '/about' },
    { label: 'Contact', href: '/contact' },
  ],
  'Legal': [
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Terms of Service', href: '/terms' },
    { label: 'Affiliate Disclosure', href: '/disclosure' },
  ],
};
---

<footer class="bg-gray-900 text-gray-300 mt-20">
  <div class="container-custom py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1">
        <img src="/logo.svg" alt="ProofLabs" style="height: 40px; margin-bottom: 1rem; filter: brightness(0) invert(1);" />
        <p class="text-sm text-gray-400 mb-4">
          Data-driven credit card reviews and comparisons to help you make informed financial decisions.
        </p>
        <p class="text-xs text-gray-500">
          © {currentYear} ProofLabs Editorial Team.<br/>
          All recommendations are based on independent analysis.
        </p>
      </div>
      
      <!-- Link Columns -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h4 class="font-semibold text-white mb-4">{category}</h4>
          <ul class="space-y-2">
            {links.map(link => (
              <li>
                <a href={link.href} class="text-sm hover:text-primary-400 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <!-- Disclosure -->
    <div class="mt-12 pt-8 border-t border-gray-800">
      <div style="background: rgba(255,255,255,0.05); border-radius: var(--radius-md); padding: 1.5rem; border: 1px solid rgba(255,255,255,0.1);">
        <div style="display: flex; align-items: flex-start; gap: 1rem;">
          <svg style="width: 1.5rem; height: 1.5rem; color: #60a5fa; flex-shrink: 0; margin-top: 0.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <p style="font-size: 0.875rem; color: #d1d5db; line-height: 1.6;">
              <strong style="color: #e5e7eb;">Affiliate Disclosure:</strong> ProofLabs may earn a commission when you apply for credit cards through links on this site. This compensation helps support our research and editorial work. Our reviews and rankings are based on objective analysis and are not influenced by affiliate relationships. We prioritize accuracy and reader value in all our recommendations.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

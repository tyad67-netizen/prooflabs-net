---
const navLinks = [
  { label: 'Articles', href: '/articles' },
  { label: 'Strategies', href: '/strategies' },
  { label: 'Cards', href: '/best-credit-cards' },
  { label: 'Savings', href: '/banking/high-yield-savings' },
  { label: 'Referrals', href: '/how-we-make-money' },
  { label: 'About', href: '/about' },
];
---

<header style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border-light); position: sticky; top: 0; z-index: 50; box-shadow: 0 1px 2px rgba(0,0,0,0.02);">
  <nav class="container-custom" style="padding: 1.25rem 0;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <!-- Logo -->
      <a href="/" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
        <img src="/logo-icon.png" alt="ProofLabs" style="height: 60px; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.1));" />
        <div style="display: flex; flex-direction: column; justify-content: center;">
          <span style="font-family: system-ui, -apple-system, sans-serif; font-size: 1.375rem; font-weight: 700; color: #111827; line-height: 1.2;">ProofLabs</span>
          <span style="font-family: system-ui, -apple-system, sans-serif; font-size: 0.625rem; font-weight: 500; color: #6b7280; letter-spacing: 0.05em;">MAXIMIZE EVERY DOLLAR</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="md:flex" style="display: none; align-items: center; gap: 2.5rem;">
        {navLinks.map(link => (
          <a
            href={link.href}
            style="color: var(--color-text-muted); font-weight: 500; font-size: 1rem; text-decoration: none; transition: color 0.2s; white-space: nowrap; display: inline-block;"
            onmouseover="this.style.color='var(--color-primary)';"
            onmouseout="this.style.color='var(--color-text-muted)';"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        style="display: block; padding: 0.5rem; color: var(--color-text-muted);"
        class="md:hidden"
        aria-label="Toggle menu"
      >
        <svg style="width: 1.5rem; height: 1.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" style="display: none; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border-light);">
      {navLinks.map(link => (
        <a
          href={link.href}
          style="display: block; padding: 0.75rem 0; color: var(--color-text-muted); font-weight: 500; text-decoration: none; transition: color 0.2s;"
          onmouseover="this.style.color='var(--color-primary)';"
          onmouseout="this.style.color='var(--color-text-muted)';"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    if (menu) {
      const isHidden = menu.style.display === 'none';
      menu.style.display = isHidden ? 'block' : 'none';
    }
  });
</script>

<style>
  @media (min-width: 768px) {
    .md\:flex {
      display: flex !important;
    }
    .md\:hidden {
      display: none !important;
    }
  }
</style>

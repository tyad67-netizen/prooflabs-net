---
interface Props {
  variant?: 'inline' | 'hero' | 'exit' | 'article-end';
  headline?: string;
  description?: string;
  leadMagnet?: string;
  buttonText?: string;
}

const {
  variant = 'inline',
  headline = "Get Tyler's Cash Back Tracking Spreadsheet",
  description = "The same Google Sheets template I use to track my $3,500+/year in rewards.",
  leadMagnet = "Cash Back Tracking Spreadsheet",
  buttonText = "Send me the spreadsheet",
} = Astro.props;
---

<div class={`email-capture email-capture--${variant}`} data-variant={variant}>
  {variant === 'hero' && (
    <div class="mascot-spot mascot-celebrate" aria-hidden="true" style="text-align: center; font-size: 3rem; margin-bottom: 1rem;">
      <span class="mascot-emoji">🦔</span>
      <!-- MASCOT: Proof celebrating with pom-poms -->
    </div>
  )}

  <div class="email-capture__content">
    <h3 class="email-capture__headline">{headline}</h3>
    <p class="email-capture__description">{description}</p>
  </div>

  <form class="email-capture__form" data-email-form>
    <div class="email-capture__input-group">
      <input
        type="email"
        name="email"
        placeholder="Enter your email"
        required
        class="email-capture__input"
        aria-label="Email address"
      />
      <button type="submit" class="email-capture__button">
        {buttonText}
      </button>
    </div>
    <div class="email-capture__privacy">
      No spam. Unsubscribe anytime. <!-- TODO: Connect to Beehiiv/ConvertKit API endpoint -->
    </div>
  </form>

  <div class="email-capture__success" data-success-message style="display: none;">
    <div style="font-size: 1.5rem; margin-bottom: 0.5rem;">🦔</div>
    <div style="font-weight: 700; margin-bottom: 0.5rem;">Thanks! You're on the list</div>
    <div style="font-size: 0.875rem; color: var(--color-text-muted);">
      Tyler will connect this to the actual email system soon. Your email is saved locally for now.
    </div>
  </div>
</div>

<style>
  .email-capture {
    margin: 2rem 0;
  }

  .email-capture--inline {
    background-color: #fef3c7;
    border-left: 4px solid var(--color-accent);
    padding: 1.5rem;
    border-radius: var(--radius-md);
  }

  .email-capture--hero {
    background: linear-gradient(135deg, #fef3c7 0%, #fed7aa 100%);
    border: 2px solid var(--color-accent);
    padding: 3rem 2rem;
    border-radius: var(--radius-lg);
    text-align: center;
    box-shadow: var(--shadow-lg);
  }

  .email-capture--article-end {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border-light);
    padding: 2rem;
    border-radius: var(--radius-lg);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: center;
  }

  .email-capture--article-end::before {
    content: '🦔';
    font-size: 4rem;
    line-height: 1;
  }

  @media (max-width: 640px) {
    .email-capture--article-end {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .email-capture--article-end::before {
      grid-column: 1;
      font-size: 3rem;
    }
  }

  .email-capture__headline {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 0.5rem 0;
    font-family: var(--font-heading);
  }

  .email-capture--inline .email-capture__headline {
    font-size: 1.25rem;
  }

  .email-capture--hero .email-capture__headline {
    font-size: 2rem;
  }

  .email-capture__description {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem 0;
    line-height: 1.6;
  }

  .email-capture--inline .email-capture__description {
    font-size: 0.9375rem;
    margin-bottom: 1rem;
  }

  .email-capture__form {
    margin: 0;
  }

  .email-capture__input-group {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .email-capture--inline .email-capture__input-group {
    flex-direction: row;
  }

  .email-capture--hero .email-capture__input-group {
    max-width: 32rem;
    margin: 0 auto 0.5rem auto;
  }

  @media (max-width: 640px) {
    .email-capture__input-group {
      flex-direction: column;
    }
  }

  .email-capture__input {
    flex: 1;
    padding: 0.875rem 1rem;
    font-size: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background-color: white;
    font-family: var(--font-body);
  }

  .email-capture__input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(241, 134, 67, 0.1);
  }

  .email-capture__button {
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    color: white;
    background-color: var(--color-accent);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.2s;
    font-family: var(--font-body);
    white-space: nowrap;
  }

  .email-capture__button:hover {
    background-color: #e67e22;
  }

  .email-capture__privacy {
    font-size: 0.75rem;
    color: var(--color-text-light);
    text-align: center;
  }

  .email-capture--inline .email-capture__privacy {
    text-align: left;
    margin-top: 0.5rem;
  }

  .email-capture__success {
    text-align: center;
    padding: 2rem;
    background-color: #f0fdf4;
    border: 2px solid #22c55e;
    border-radius: var(--radius-md);
    color: #166534;
  }
</style>

<script>
  document.querySelectorAll('[data-email-form]').forEach(form => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const emailInput = form.querySelector('input[name="email"]') as HTMLInputElement;
      const email = emailInput?.value;

      if (email) {
        // Store in localStorage as placeholder
        localStorage.setItem('prooflabs_email', email);

        // Hide form, show success
        (form as HTMLElement).style.display = 'none';
        const successMessage = form.parentElement?.querySelector('[data-success-message]') as HTMLElement;
        if (successMessage) {
          successMessage.style.display = 'block';
        }
      }
    });
  });
</script>

---
interface Card {
  name: string;
  signUpBonus: string;
  rewardsRate: string;
  annualFee: string;
  bestFor: string;
  affiliateLink?: string;
}

interface Props {
  cards: Card[];
}

const { cards } = Astro.props;

// Helper to format comma-separated text as bullet list
function formatAsList(text: string): string[] {
  return text.split(',').map(item => item.trim()).filter(item => item.length > 0);
}
---

<div class="comparison-table">
  <h2>Quick Comparison: Top 3 Cards</h2>
  <table>
    <thead>
      <tr>
        <th>Card</th>
        <th>Sign-Up Bonus</th>
        <th>Rewards Rate</th>
        <th>Annual Fee</th>
        <th>Best For</th>
      </tr>
    </thead>
    <tbody>
      {cards.map((card) => (
        <tr>
          <td><strong>{card.name}</strong></td>
          <td>{card.signUpBonus}</td>
          <td>
            <ul class="rewards-list">
              {formatAsList(card.rewardsRate).map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </td>
          <td><strong>{card.annualFee}</strong></td>
          <td>{card.bestFor}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .comparison-table {
    margin: 2rem 0;
  }
  
  table {
    width: 100%;
    border-collapse: collapse;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  
  th {
    background-color: #f5f5f5;
    font-weight: 600;
    padding: 12px;
    text-align: left;
    border-bottom: 2px solid #ddd;
  }
  
  td {
    padding: 12px;
    border-bottom: 1px solid #eee;
    vertical-align: top;
  }
  
  tr:hover {
    background-color: #fafafa;
  }
  
  .rewards-list {
    margin: 0;
    padding-left: 1.2rem;
    list-style-type: disc;
  }
  
  .rewards-list li {
    margin: 0.3rem 0;
    line-height: 1.4;
  }
</style>

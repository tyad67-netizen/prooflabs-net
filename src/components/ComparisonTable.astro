---
interface Card {
  name: string;
  signUpBonus: string;
  rewardsRate: string;
  annualFee: string;
  bestFor: string;
  affiliateLink?: string;
}

interface Props {
  cards: Card[];
}

const { cards } = Astro.props;

// Helper to format comma-separated text as bullet list
function formatAsList(text: string): string[] {
  return text.split(',').map(item => item.trim()).filter(item => item.length > 0);
}
---

<div class="comparison-table">
  <h2>Quick Comparison: Top 3 Cards</h2>
  <table>
    <thead>
      <tr>
        <th>Card</th>
        <th>Sign-Up Bonus</th>
        <th>Rewards Rate</th>
        <th>Annual Fee</th>
        <th>Best For</th>
      </tr>
    </thead>
    <tbody>
      {cards.map((card) => (
        <tr>
          <td><strong>{card.name}</strong></td>
          <td>{card.signUpBonus}</td>
          <td>
            <ul class="rewards-list">
              {formatAsList(card.rewardsRate).map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </td>
          <td><strong>{card.annualFee}</strong></td>
          <td>{card.bestFor}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .comparison-table {
    margin: 3rem 0;
  }
  
  .comparison-table h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: #111827;
  }
  
  table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0,0,0,0.06);
  }
  
  th {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    font-weight: 700;
    padding: 1rem;
    text-align: left;
    color: #0369a1;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 2px solid #0284c7;
  }
  
  td {
    padding: 1.25rem 1rem;
    border-bottom: 1px solid #f3f4f6;
    vertical-align: top;
    color: #374151;
  }
  
  tbody tr:last-child td {
    border-bottom: none;
  }
  
  tbody tr:hover {
    background-color: #f9fafb;
  }
  
  td strong {
    color: #111827;
    font-weight: 700;
  }
  
  .rewards-list {
    margin: 0;
    padding-left: 1.25rem;
    list-style-type: none;
  }
  
  .rewards-list li {
    margin: 0.5rem 0;
    line-height: 1.6;
    position: relative;
  }
  
  .rewards-list li:before {
    content: "•";
    color: #0284c7;
    font-weight: bold;
    position: absolute;
    left: -1.25rem;
  }
  
  @media (max-width: 768px) {
    table {
      font-size: 0.875rem;
    }
    
    th, td {
      padding: 0.75rem 0.5rem;
    }
  }
</style>

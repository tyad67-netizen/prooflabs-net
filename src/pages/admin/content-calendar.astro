---
import BaseLayout from '../../layouts/BaseLayout.astro';

const calendar = [
  {
    week: "Week 1-2: Foundation Content (P1)",
    articles: [
      { url: "/strategies/secret-sauce", title: "How I Earn $3,500+/Year in Rewards", primaryKW: "credit card rewards strategy", words: 2500, priority: "P1", status: "TODO", notes: "THE flagship piece. Tyler's complete system." },
      { url: "/strategies/how-to-pay-rent-with-credit-card", title: "How to Pay Rent with a Credit Card (and Earn Points)", primaryKW: "pay rent with credit card", words: 2000, priority: "P1", status: "TODO", notes: "BILT expertise, massive search volume." },
      { url: "/credit-cards/best-credit-card-for-rent", title: "Best Credit Card for Rent 2026", primaryKW: "best credit card for rent", words: 1800, priority: "P1", status: "TODO", notes: "BILT 2.0 vs BILT Cash vs alternatives." },
      { url: "/strategies/credit-card-stacking", title: "Credit Card Stacking: How to Maximize Rewards with Multiple Cards", primaryKW: "credit card stacking", words: 2000, priority: "P1", status: "TODO", notes: "Tyler's 3-card system explained." },
    ]
  },
  {
    week: "Week 3-4: Expand Credit Card Coverage (P1)",
    articles: [
      { url: "/credit-cards/best-credit-card-for-dining", title: "Best Credit Card for Dining 2026", primaryKW: "best credit card for dining", words: 1800, priority: "P1", status: "TODO" },
      { url: "/credit-cards/best-credit-card-for-costco", title: "Best Credit Card for Costco 2026", primaryKW: "best credit card for Costco", words: 1500, priority: "P1", status: "TODO", notes: "Tyler's Costco expertise." },
      { url: "/credit-cards/best-credit-card-no-annual-fee", title: "Best No Annual Fee Credit Card 2026", primaryKW: "best no annual fee credit card", words: 1800, priority: "P1", status: "TODO" },
      { url: "/credit-cards/best-flat-rate-cash-back-card", title: "Best Flat Rate Cash Back Card 2026", primaryKW: "best flat rate cash back card", words: 1500, priority: "P1", status: "TODO" },
      { url: "/credit-cards/best-3-card-stack-2026", title: "Best 3-Card Stack 2026", primaryKW: "best credit card combo", words: 2000, priority: "P1", status: "TODO", notes: "THE unique content piece." },
    ]
  },
  {
    week: "Week 5-6: Banking Vertical (P1)",
    articles: [
      { url: "/banking/high-yield-savings", title: "Best High Yield Savings Account 2026", primaryKW: "best high yield savings account", words: 2000, priority: "P1", status: "TODO", notes: "Tyler uses all platforms." },
      { url: "/banking/robinhood-vs-sofi-vs-wealthfront-savings", title: "Robinhood vs SoFi vs Wealthfront Savings 2026", primaryKW: "Robinhood vs SoFi savings", words: 1800, priority: "P1", status: "TODO", notes: "Tyler uses all three." },
      { url: "/banking/robinhood-savings-review", title: "Robinhood Savings Review 2026", primaryKW: "Robinhood savings review", words: 1200, priority: "P1", status: "TODO" },
      { url: "/banking/sofi-savings-review", title: "SoFi Savings Review 2026", primaryKW: "SoFi savings review", words: 1200, priority: "P1", status: "TODO" },
      { url: "/banking/wealthfront-savings-review", title: "Wealthfront Savings Review 2026", primaryKW: "Wealthfront savings review", words: 1200, priority: "P1", status: "TODO" },
    ]
  },
  {
    week: "Week 7-8: Cashback Stacking & Comparisons (P1)",
    articles: [
      { url: "/strategies/cashback-stacking", title: "How to Stack Cashback: Rakuten + Credit Cards + Browser Extensions", primaryKW: "cashback stacking", words: 2000, priority: "P1", status: "TODO" },
      { url: "/strategies/rakuten-guide", title: "Rakuten Guide: How I Earned $1,000 in Cashback", primaryKW: "Rakuten review", words: 1500, priority: "P1", status: "TODO" },
      { url: "/credit-cards/amex-blue-cash-everyday-vs-amex-blue-cash-preferred", title: "Amex Blue Cash Everyday vs Amex Blue Cash Preferred", primaryKW: "blue cash everyday vs preferred", words: 1500, priority: "P1", status: "TODO" },
      { url: "/credit-cards/chase-freedom-unlimited-vs-citi-double-cash", title: "Chase Freedom Unlimited vs Citi Double Cash", primaryKW: "chase freedom unlimited vs citi double cash", words: 1500, priority: "P1", status: "TODO" },
    ]
  },
  {
    week: "Week 9-10: Investing Vertical (P2)",
    articles: [
      { url: "/investing/best-free-investing-platforms", title: "Best Free Investing Platforms 2026", primaryKW: "best free investing platform", words: 1800, priority: "P2", status: "TODO" },
      { url: "/investing/robinhood-vs-webull-vs-schwab", title: "Robinhood vs Webull vs Schwab 2026", primaryKW: "Robinhood vs Webull", words: 1800, priority: "P2", status: "TODO" },
      { url: "/investing/robinhood-review", title: "Robinhood Review 2026", primaryKW: "Robinhood review 2026", words: 1200, priority: "P2", status: "TODO" },
      { url: "/investing/platform-bonuses", title: "Best Investing Sign-Up Bonuses 2026", primaryKW: "investing sign up bonus", words: 1500, priority: "P2", status: "TODO" },
    ]
  },
  {
    week: "Week 11-12: TOFU + Remaining Content (P2-P3)",
    articles: [
      { url: "/learn/what-is-cash-back", title: "What Is Cash Back on a Credit Card?", primaryKW: "what is cash back credit card", words: 1000, priority: "P3", status: "TODO" },
      { url: "/learn/how-credit-scores-work", title: "How Credit Scores Work", primaryKW: "how credit scores work", words: 1200, priority: "P3", status: "TODO" },
      { url: "/learn/credit-card-stacking-explained", title: "Credit Card Stacking Explained", primaryKW: "credit card stacking explained", words: 1000, priority: "P3", status: "TODO" },
      { url: "/credit-cards/best-credit-card-for-amazon", title: "Best Credit Card for Amazon 2026", primaryKW: "best credit card for Amazon", words: 1500, priority: "P2", status: "TODO" },
      { url: "/credit-cards/best-credit-card-for-streaming", title: "Best Credit Card for Streaming Services 2026", primaryKW: "best credit card for streaming", words: 1200, priority: "P2", status: "TODO" },
      { url: "/strategies/bilt-points-guide", title: "BILT Points Guide: Earn 30,000+ Points Per Year", primaryKW: "BILT points guide", words: 1500, priority: "P2", status: "TODO", notes: "Tyler's 30K points/year expertise." },
      { url: "/crypto/best-crypto-platforms", title: "Best Crypto Platforms 2026", primaryKW: "best crypto platform", words: 1500, priority: "P2", status: "TODO" },
      { url: "/crypto/coinbase-vs-robinhood-crypto", title: "Coinbase vs Robinhood Crypto 2026", primaryKW: "Coinbase vs Robinhood crypto", words: 1200, priority: "P2", status: "TODO" },
    ]
  },

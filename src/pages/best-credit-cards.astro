---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'Best Cash Back Credit Cards',
    description: 'Maximize everyday spending with top cashback rewards',
    href: '/categories/cash-back',
    color: '#10b981'
  },
];

const featuredReviews = [
  {
    title: 'Best Credit Card for Rent Payments',
    href: '/credit-cards/best-credit-card-for-rent',
  },
  {
    title: 'Credit Card Stacking Explained',
    href: '/strategies/credit-card-stacking',
  },
  {
    title: 'Why I Pay $495/Year for the BILT Palladium',
    href: '/strategies/bilt-palladium-deep-dive',
  },
  {
    title: 'The Costco Stack: 6% on Groceries',
    href: '/strategies/costco-executive-visa-stack',
  },
  {
    title: 'BILT Rent Day: The 4x Multiplier Strategy',
    href: '/strategies/rent-day-optimization',
  },
];
---

<BaseLayout
  title="Best Credit Cards of 2026 \u2014 Tyler's Picks & Reviews"
  description="Independent credit card reviews based on real spending data. Cards Tyler actually uses, with the math to back it up."
>
  <div class="container-custom" style="padding: 5rem 0 6rem;">
    <div style="max-width: 52rem; margin: 0 auto;">
      <div style="margin-bottom: 3rem;">
        <h1 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 0.75rem; color: var(--color-text);">
          Best Credit Cards of 2026
        </h1>
        <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7;">
          Independent reviews based on real spending data. Every card here is one Tyler actually uses or has tested with real money.
        </p>
      </div>

      <!-- Categories -->
      <div style="margin-bottom: 3.5rem;">
        <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--color-text);">
          Browse by Category
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
          {categories.map(category => (
            <a href={category.href} style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.75rem; text-decoration: none; color: inherit; transition: all 0.2s;" onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,0.08)';" onmouseout="this.style.boxShadow='none';">
              <div style={`width: 2.5rem; height: 2.5rem; border-radius: var(--radius-sm); background: ${category.color}; margin-bottom: 1rem;`}></div>
              <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text);">
                {category.title}
              </h3>
              <p style="color: var(--color-text-muted); line-height: 1.6; margin: 0; font-size: 0.9375rem;">
                {category.description}
              </p>
            </a>
          ))}
        </div>
        <p style="font-size: 0.875rem; color: var(--color-text-light); margin-top: 1rem;">
          More categories coming soon as part of our weekly publishing schedule.
        </p>
      </div>

      <!-- Featured Reviews -->
      <div>
        <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--color-text);">
          Featured Reviews & Guides
        </h2>
        <div style="display: grid; gap: 0.75rem;">
          {featuredReviews.map(review => (
            <a href={review.href} style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.25rem 1.5rem; text-decoration: none; color: inherit; display: flex; justify-content: space-between; align-items: center; transition: border-color 0.2s;" onmouseover="this.style.borderColor='#d1d5db';" onmouseout="this.style.borderColor='var(--color-border-light)';">
              <span style="font-size: 1rem; font-weight: 600; color: var(--color-text);">{review.title}</span>
              <svg style="width: 1.25rem; height: 1.25rem; color: var(--color-text-light); flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

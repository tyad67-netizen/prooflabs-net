---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact ProofLabs - Get in Touch"
  description="Contact the ProofLabs editorial team with questions, feedback, or partnership inquiries."
>
  <div class="container-custom" style="padding: 8rem 0 6rem;">
    <div style="max-width: 48rem; margin: 0 auto;">
      <h1 style="font-size: 3rem; font-weight: 900; margin-bottom: 2rem; color: var(--color-text);">
        Contact Us
      </h1>
      
      <div style="font-size: 1.125rem; line-height: 1.8; color: var(--color-text-muted);">
        <p style="margin-bottom: 3rem;">
          Have questions about our reviews, methodology, or want to report an error? We'd love to hear from you.
        </p>
        
        <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2rem;">
          <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--color-text);">
            Editorial Inquiries
          </h2>
          <p style="margin-bottom: 1rem;">
            For questions about our reviews, methodology, or to report inaccurate information:
          </p>
          <p style="margin-bottom: 0;">
            <strong>Email:</strong> <a href="mailto:editorial@prooflabs.net" style="color: var(--color-secondary); text-decoration: underline;">editorial@prooflabs.net</a>
          </p>
        </div>
        
        <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2rem;">
          <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--color-text);">
            Partnership Opportunities
          </h2>
          <p style="margin-bottom: 1rem;">
            For business development and partnership inquiries:
          </p>
          <p style="margin-bottom: 0;">
            <strong>Email:</strong> <a href="mailto:partnerships@prooflabs.net" style="color: var(--color-secondary); text-decoration: underline;">partnerships@prooflabs.net</a>
          </p>
        </div>
        
        <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); padding: 2rem;">
          <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--color-text);">
            General Support
          </h2>
          <p style="margin-bottom: 1rem;">
            For all other inquiries:
          </p>
          <p style="margin-bottom: 0;">
            <strong>Email:</strong> <a href="mailto:support@prooflabs.net" style="color: var(--color-secondary); text-decoration: underline;">support@prooflabs.net</a>
          </p>
        </div>
        
        <div style="background-color: var(--color-secondary-bg); padding: 2rem; margin: 3rem 0; border-radius: var(--radius-md);">
          <p style="margin: 0; color: var(--color-secondary-dark);">
            <strong>Note:</strong> We typically respond to inquiries within 2-3 business days. For urgent matters, please indicate "URGENT" in your subject line.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

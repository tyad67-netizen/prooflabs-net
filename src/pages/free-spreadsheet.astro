---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<BaseLayout
  title="Free Cash Back Tracking Spreadsheet | ProofLabs"
  description="Download Tyler's personal Google Sheets template for tracking credit card rewards across all spending categories. The same system behind $3,500+/year in cashback."
>
  <div class="container-custom" style="padding: 8rem 0 6rem;">
    <div style="max-width: 48rem; margin: 0 auto; text-align: center;">
      <div class="mascot-spot mascot-celebrate" aria-hidden="true" style="font-size: 5rem; margin-bottom: 2rem;">
        <span class="mascot-emoji">🦔</span>
        <!-- MASCOT: Proof celebrating with the spreadsheet -->
      </div>

      <h1 style="font-size: 3rem; font-weight: 900; margin-bottom: 1rem; color: var(--color-text);">
        My Cash Back Tracking Spreadsheet — Free
      </h1>
      
      <p style="font-size: 1.5rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 3rem;">
        The same Google Sheets template I use to earn $3,500+/year in rewards
      </p>

      <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); padding: 3rem; margin-bottom: 3rem; text-align: left;">
        <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--color-text); text-align: center;">
          What's Included
        </h2>

        <div style="display: grid; gap: 1.5rem;">
          <div style="display: flex; align-items: start; gap: 1rem;">
            <div style="flex-shrink: 0; width: 2rem; height: 2rem; background-color: var(--color-accent); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700;">
              1
            </div>
            <div>
              <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">
                Track card rewards by category
              </h3>
              <p style="color: var(--color-text-muted); line-height: 1.7;">
                See exactly how much each card earns across groceries, gas, dining, and all other categories.
              </p>
            </div>
          </div>

          <div style="display: flex; align-items: start; gap: 1rem;">
            <div style="flex-shrink: 0; width: 2rem; height: 2rem; background-color: var(--color-accent); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700;">
              2
            </div>
            <div>
              <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">
                Calculate your actual annual value
              </h3>
              <p style="color: var(--color-text-muted); line-height: 1.7;">
                Plug in your monthly spending and see your total rewards minus all annual fees — your net value.
              </p>
            </div>
          </div>

          <div style="display: flex; align-items: start; gap: 1rem;">
            <div style="flex-shrink: 0; width: 2rem; height: 2rem; background-color: var(--color-accent); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700;">
              3
            </div>
            <div>
              <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">
                Compare card combos
              </h3>
              <p style="color: var(--color-text-muted); line-height: 1.7;">
                Test different 2-3 card stacks to find which combination maximizes your returns.
              </p>
            </div>
          </div>

          <div style="display: flex; align-items: start; gap: 1rem;">
            <div style="flex-shrink: 0; width: 2rem; height: 2rem; background-color: var(--color-accent); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700;">
              4
            </div>
            <div>
              <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">
                See which categories are under-optimized
              </h3>
              <p style="color: var(--color-text-muted); line-height: 1.7;">
                Identify spending categories where you're leaving money on the table.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div style="background-color: #f0fdf4; border: 2px solid #22c55e; border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 3rem;">
        <p style="color: #166534; font-size: 0.875rem; margin: 0;">
          <!-- TODO: Add screenshot of actual spreadsheet -->
          <strong>Screenshot coming soon:</strong> Tyler will add a real screenshot of the spreadsheet in action showing the full tracking system.
        </p>
      </div>

      <EmailCapture
        variant="hero"
        headline="Get the Spreadsheet"
        description="Enter your email and get instant access to the Google Sheets template."
        buttonText="Send me the spreadsheet"
      />

      <div style="margin-top: 3rem; padding-top: 3rem; border-top: 1px solid var(--color-border-light);">
        <div style="display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 1rem;">
          <img src="/logo.svg" alt="ProofLabs" style="height: 48px;" />
        </div>
        <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.7; margin-bottom: 0.5rem;">
          <strong>I'm Tyler, founder of ProofLabs.</strong> I built this spreadsheet to manage my own card stack and track my real returns.
        </p>
        <p style="color: var(--color-text-light); font-size: 0.875rem;">
          No fluff, no upsells. Just the tool I actually use to earn $3,500+/year in rewards.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

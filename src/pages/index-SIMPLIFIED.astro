---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Maximize Every Dollar You Spend"
  description="Real strategies for credit card optimization and cashback stacking. Same spending, better returns."
>
  <!-- Hero Section -->
  <section style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 5rem 0 6rem;">
      <div style="max-width: 48rem; margin: 0 auto; text-align: center;">
        <div style="margin-bottom: 1.75rem;">
          <img src="/proof-happy-clean.png" alt="Proof the Hedgehog" style="width: 120px; height: auto; margin: 0 auto; display: block;" />
        </div>

        <h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 1.5rem; line-height: 1.15; color: var(--color-text); letter-spacing: -0.025em;">
          Maximize cash back from the spending you already do
        </h1>

        <p style="font-size: 1.3rem; color: var(--color-text-muted); margin-bottom: 2.5rem; max-width: 42rem; margin-left: auto; margin-right: auto; line-height: 1.65;">
          Real strategies, actual math, zero fluff. Learn how I earned $3,500+ from credit cards without changing my lifestyle.
        </p>

        <!-- Primary CTA: Rakuten -->
        <div style="background: linear-gradient(135deg, #FFF5E6 0%, #F5BC6E 100%); border: 2px solid var(--color-primary); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2rem; max-width: 36rem; margin-left: auto; margin-right: auto;">
          <div style="font-size: 0.875rem; font-weight: 700; color: var(--color-primary-dark); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">
            💰 Free $50 Bonus
          </div>
          <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;">
            Get $50 from Rakuten
          </h2>
          <p style="font-size: 1rem; color: var(--color-text-muted); margin-bottom: 1.25rem; line-height: 1.6;">
            Stack cashback portals with your credit cards. I've earned $467.50 in referrals alone—here's your $50 to start.
          </p>
          <a href="https://www.rakuten.com/r/TYLERM3316?eeid=28187" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; justify-content: center; padding: 1rem 2.5rem; background-color: var(--color-accent); color: white; border-radius: var(--radius-full); font-weight: 700; font-size: 1.125rem; text-decoration: none; transition: all 0.2s; box-shadow: 0 4px 12px rgba(212, 91, 63, 0.3);" onmouseover="this.style.backgroundColor='var(--color-accent-dark)'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='var(--color-accent)'; this.style.transform='translateY(0)';">
            Claim $50 Rakuten Bonus →
          </a>
        </div>

        <!-- Email Signup -->
        <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; max-width: 36rem; margin-left: auto; margin-right: auto;">
          <div style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;">
            📬 Join 500+ readers
          </div>
          <p style="font-size: 0.9375rem; color: var(--color-text-muted); margin-bottom: 1.25rem; line-height: 1.6;">
            Get weekly credit card strategies, cashback optimization tips, and exclusive breakdowns.
          </p>
          <form style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <input type="email" placeholder="your@email.com" style="flex: 1; min-width: 200px; padding: 0.875rem 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); font-size: 1rem; background: var(--color-surface);" />
            <button type="submit" style="padding: 0.875rem 2rem; background-color: var(--color-secondary); color: white; border: none; border-radius: var(--radius-md); font-weight: 600; font-size: 1rem; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.backgroundColor='var(--color-secondary-dark)';" onmouseout="this.style.backgroundColor='var(--color-secondary)';">
              Subscribe
            </button>
          </form>
          <p style="font-size: 0.75rem; color: var(--color-text-light); margin-top: 0.75rem;">
            No spam. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  <section style="background-color: var(--color-bg-alt); padding: 5rem 0;">
    <div class="container-custom">
      <div style="max-width: 64rem; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 3rem;">
          <h2 style="font-size: 2rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;">
            Start here: Real strategies, backed by math
          </h2>
          <p style="font-size: 1.125rem; color: var(--color-text-muted); max-width: 42rem; margin: 0 auto;">
            Data-driven articles breaking down credit card optimization, cashback stacking, and rewards strategies.
          </p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
          <!-- Article 1: Secret Sauce -->
          <a href="/strategies/secret-sauce" style="display: block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-primary)'; this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.08)';" onmouseout="this.style.borderColor='var(--color-border)'; this.style.transform='translateY(0)'; this.style.boxShadow='none';">
            <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">
              ⭐ Start Here
            </div>
            <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem; line-height: 1.3;">
              The Secret Sauce: My Complete Strategy
            </h3>
            <p style="font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 1rem;">
              How I earn $3,500+/year from credit cards. My exact 4-card stack, the math behind it, and how to replicate it.
            </p>
            <div style="font-size: 0.875rem; color: var(--color-secondary); font-weight: 600;">
              Read strategy →
            </div>
          </a>

          <!-- Article 2: Chase Sapphire Break-Even -->
          <a href="/articles/2026-03-23" style="display: block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-primary)'; this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.08)';" onmouseout="this.style.borderColor='var(--color-border)'; this.style.transform='translateY(0)'; this.style.boxShadow='none';">
            <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">
              Latest
            </div>
            <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem; line-height: 1.3;">
              Chase Sapphire Preferred: The Real Math on $95
            </h3>
            <p style="font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 1rem;">
              Most people lose $188/year on this card. Here's the exact spend you need to break even—and who actually comes out ahead.
            </p>
            <div style="font-size: 0.875rem; color: var(--color-secondary); font-weight: 600;">
              Read breakdown →
            </div>
          </a>

          <!-- Article 3: Rakuten Stacking -->
          <a href="/strategies/rakuten-bilt-stacking" style="display: block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-primary)'; this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.08)';" onmouseout="this.style.borderColor='var(--color-border)'; this.style.transform='translateY(0)'; this.style.boxShadow='none';">
            <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">
              Strategy
            </div>
            <h3 style="font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem; line-height: 1.3;">
              Stacking Rakuten + BILT for 17%+ Returns
            </h3>
            <p style="font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 1rem;">
              How to stack cashback portals with credit cards for double-digit returns on everyday purchases. Real examples included.
            </p>
            <div style="font-size: 0.875rem; color: var(--color-secondary); font-weight: 600;">
              Read strategy →
            </div>
          </a>
        </div>

        <!-- All Strategies Link -->
        <div style="text-align: center; margin-top: 3rem;">
          <a href="/strategies" style="display: inline-flex; align-items: center; justify-content: center; padding: 1rem 2rem; background-color: var(--color-surface); color: var(--color-text); border: 2px solid var(--color-border); border-radius: var(--radius-full); font-weight: 600; font-size: 1rem; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-primary)'; this.style.backgroundColor='var(--color-bg-alt)';" onmouseout="this.style.borderColor='var(--color-border)'; this.style.backgroundColor='var(--color-surface)';">
            Browse all strategies →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof / Follow -->
  <section style="background-color: var(--color-surface); padding: 4rem 0; border-top: 1px solid var(--color-border-light);">
    <div class="container-custom">
      <div style="max-width: 42rem; margin: 0 auto; text-align: center;">
        <h3 style="font-size: 1.75rem; font-weight: 700; color: var(--color-text); margin-bottom: 1rem;">
          Follow on X for daily threads
        </h3>
        <p style="font-size: 1.125rem; color: var(--color-text-muted); margin-bottom: 2rem; line-height: 1.6;">
          Credit card strategies, cashback breakdowns, and the math nobody shows you. Delivered daily.
        </p>
        <a href="https://x.com/TheProofLabs" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; justify-content: center; padding: 1rem 2.5rem; background-color: #000; color: white; border-radius: var(--radius-full); font-weight: 600; font-size: 1.125rem; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.backgroundColor='#1a1a1a';" onmouseout="this.style.backgroundColor='#000';">
          Follow @TheProofLabs →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

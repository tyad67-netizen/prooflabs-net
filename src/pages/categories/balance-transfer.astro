---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categoryName = "Balance Transfer";
const description = "Balance transfer credit cards offer 0% intro APR periods to help you pay down existing debt without accumulating interest. Find cards with the longest intro periods and lowest transfer fees.";

// Balance transfer articles (currently none exist - show coming soon)
const reviews = [];
---

<BaseLayout
  title={`Best ${categoryName} Credit Cards of 2026`}
  description={`Find the best ${categoryName.toLowerCase()} credit cards with our independent reviews. Compare intro APR periods and transfer fees.`}
>
  <div class="container-custom" style="padding: 8rem 0 6rem;">
    <div style="max-width: 56rem; margin: 0 auto;">
      <h1 style="font-size: 3rem; font-weight: 900; margin-bottom: 1.5rem; color: var(--color-text);">
        Best {categoryName} Credit Cards
      </h1>
      
      <p style="font-size: 1.25rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 3rem;">
        {description}
      </p>
      
      <div style="background-color: var(--color-secondary-bg); border-left: 4px solid #0284c7; padding: 2rem; margin-bottom: 4rem; border-radius: var(--radius-md);">
        <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--color-secondary-dark);">
          What to Look For
        </h2>
        <ul style="color: var(--color-secondary-dark); padding-left: 1.5rem;">
          <li style="margin-bottom: 0.5rem;">Intro 0% APR period length (12-21 months typical)</li>
          <li style="margin-bottom: 0.5rem;">Balance transfer fee percentage (3-5% typical)</li>
          <li style="margin-bottom: 0.5rem;">Regular APR after intro period ends</li>
          <li style="margin-bottom: 0.5rem;">Credit score requirements</li>
          <li style="margin-bottom: 0.5rem;">Whether new purchases also get 0% intro rate</li>
        </ul>
      </div>
      
      <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 2rem; color: var(--color-text);">
        {categoryName} Card Reviews
      </h2>
      
      {reviews.length > 0 ? (
        <div style="display: grid; gap: 1rem;">
          {reviews.map(review => (
            <a href={review.href} style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.5rem; text-decoration: none; color: inherit; display: flex; justify-content: space-between; align-items: center; transition: all 0.2s;" onmouseover="this.style.background='#f9fafb';" onmouseout="this.style.background='white';">
              <span style="font-size: 1.125rem; font-weight: 600; color: var(--color-text);">{review.title}</span>
              <svg style="width: 1.25rem; height: 1.25rem; color: var(--color-secondary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          ))}
        </div>
      ) : (
        <div style="background-color: var(--color-bg-alt); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 2.5rem; text-align: center;">
          <p style="color: var(--color-text-muted); font-size: 1.125rem; margin-bottom: 1rem;">
            Reviews for this category are coming soon.
          </p>
          <p style="color: var(--color-text-light); margin-bottom: 1.5rem;">
            Check out our cash back card reviews in the meantime:
          </p>
          <a href="/categories/cash-back" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; background-color: var(--color-accent); color: white; border-radius: var(--radius-md); font-weight: 600; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='#0369a1';" onmouseout="this.style.background='#0284c7';">
            View Cash Back Cards
          </a>
        </div>
      )}
    </div>
  </div>
</BaseLayout>

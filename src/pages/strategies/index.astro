---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Optimization Strategies";
const description = "Real strategies from real spending. Tested by Tyler, backed by math.";

const strategies = [
  {
    title: "Tyler's Secret Sauce: The Complete Strategy",
    description: 'The full breakdown of how I earn $3,500+/year from money I was already spending. Every card, every portal, every trick.',
    href: '/strategies/secret-sauce',
    readTime: '15 min',
    tag: 'Start Here',
    hedgehog: '/proof-celebrating.png',
    featured: true,
  },
  {
    title: 'Why I Pay $495/Year for the BILT Palladium',
    description: "The annual fee sounds insane \u2014 until you see the rent day multipliers and Rakuten stacking.",
    href: '/strategies/bilt-palladium-deep-dive',
    readTime: '12 min',
    tag: 'Deep Dive',
    hedgehog: '/proof-thinking.png',
  },
  {
    title: 'BILT Rent Day: The 4x Multiplier Strategy',
    description: 'On the 1st of every month, 2x becomes 4x and 4% becomes 8%. Plan your spending around it.',
    href: '/strategies/rent-day-optimization',
    readTime: '11 min',
    tag: 'Strategy',
    hedgehog: '/proof-surprised.png',
  },
  {
    title: 'Stacking Rakuten with BILT for 17%+ Returns',
    description: "Rakuten cashback converts to BILT points. Add rent day multipliers and you're earning 17\u201325% on everyday purchases.",
    href: '/strategies/rakuten-bilt-stacking',
    readTime: '13 min',
    tag: 'Advanced',
    hedgehog: '/proof-surprised.png',
  },
  {
    title: 'The Costco Stack: 6% on Groceries',
    description: 'Executive membership + Costco Visa = 6% total return. Plus the shop card hack.',
    href: '/strategies/costco-executive-visa-stack',
    readTime: '10 min',
    tag: 'Strategy',
    hedgehog: '/proof-happy-clean.png',
  },
  {
    title: 'Credit Card Stacking Explained',
    description: 'The foundational concept: how combining 2\u20133 cards covers every category at the highest rate.',
    href: '/strategies/credit-card-stacking',
    readTime: '10 min',
    tag: 'Fundamentals',
    hedgehog: '/proof-thinking.png',
  },
  {
    title: 'How to Pay Rent with a Credit Card',
    description: 'Step-by-step guide to earning points on rent payments you already make every month.',
    href: '/strategies/how-to-pay-rent-with-credit-card',
    readTime: '8 min',
    tag: 'Guide',
    hedgehog: '/proof-happy-clean.png',
  },
];
---

<BaseLayout title={title} description={description}>
  <div class="container-custom" style="padding: 5rem 0 6rem;">
    <div style="max-width: 52rem; margin: 0 auto;">
      <!-- Header -->
      <div style="margin-bottom: 3rem;">
        <h1 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 0.75rem; color: var(--color-text);">
          {title}
        </h1>
        <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7;">
          {description}
        </p>
      </div>

      <!-- Strategy Cards -->
      <div style="display: grid; gap: 1.25rem;">
        {strategies.map(article => (
          <a href={article.href} style={`background-color: var(--color-surface); border: 1px solid ${article.featured ? 'var(--color-primary)' : 'var(--color-border-light)'}; border-radius: var(--radius-md); padding: 1.5rem; text-decoration: none; color: inherit; transition: border-color 0.2s, box-shadow 0.2s;${article.featured ? ' border-width: 2px;' : ''}`} onmouseover="this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)';" onmouseout="this.style.boxShadow='none';">
            <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 0.75rem;">
              <img src={article.hedgehog} alt="" style="width: 42px; height: auto; flex-shrink: 0; margin-top: 0.25rem;" />
              <div style="flex: 1;">
                <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                  <span style={`font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.15rem 0.5rem; border-radius: 4px; ${article.featured ? 'color: white; background: var(--color-primary);' : 'color: var(--color-primary); background: var(--color-primary-bg);'}`}>
                    {article.tag}
                  </span>
                  <span style="color: #d1d5db;">&middot;</span>
                  <span style="font-size: 0.7rem; color: var(--color-text-light);">{article.readTime}</span>
                </div>
                <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem; line-height: 1.35;">
                  {article.title}
                </h3>
                <p style="color: var(--color-text-muted); line-height: 1.6; font-size: 0.9rem; margin: 0;">
                  {article.description}
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Best High-Yield Savings Accounts 2026";
const description = "Robinhood, SoFi, Wealthfront and more compared. Tyler uses all three \u2014 here's where to park your cash.";

const accounts = [
  {
    name: 'SoFi Checking & Savings',
    apy: '4.00%',
    bonus: '$25\u2013$425 with direct deposit',
    highlight: "Tyler's pick for direct deposit bonuses",
    minDeposit: '$0',
    fdic: 'Up to $2M (partner banks)',
  },
  {
    name: 'Wealthfront Cash Account',
    apy: '4.00%',
    bonus: '+0.75% APY boost via referral',
    highlight: 'Best for hands-off savers',
    minDeposit: '$0',
    fdic: 'Up to $8M (partner banks)',
  },
  {
    name: 'Robinhood Gold Savings',
    apy: '4.00%',
    bonus: 'Free stock on signup',
    highlight: 'Best combined investing + savings',
    minDeposit: '$0',
    fdic: 'Up to $2.5M (program banks)',
  },
];
---

<BaseLayout title={title} description={description}>
  <div class="container-custom" style="padding: 5rem 0 6rem;">
    <div style="max-width: 52rem; margin: 0 auto;">
      <!-- Header -->
      <div style="margin-bottom: 2rem; display: flex; align-items: center; gap: 1.5rem;">
        <img src="/proof-happy-clean.png" alt="Proof" style="width: 60px; height: auto;" />
        <div style="flex: 1;">
          <h1 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 0.75rem; color: var(--color-text);">
            {title}
          </h1>
          <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7;">
            {description}
          </p>
          <p style="font-size: 0.875rem; color: var(--color-text-light); margin-top: 0.75rem;">
            Last updated: March 22, 2026
          </p>
        </div>
      </div>

      <!-- Disclosure -->
      <div style="background: var(--color-primary-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem 1.25rem; margin-bottom: 2.5rem; font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.6;">
        Some links below are referral links. Tyler may earn a bonus at no cost to you. See our <a href="/disclosure" style="color: var(--color-secondary); text-decoration: underline;">full disclosure</a>.
      </div>

      <!-- Account Cards -->
      <div style="display: grid; gap: 1.5rem; margin-bottom: 3rem;">
        {accounts.map(account => (
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
              <div style="flex: 1; min-width: 220px;">
                <h3 style="font-size: 1.2rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.35rem;">
                  {account.name}
                </h3>
                <p style="font-size: 0.875rem; color: var(--color-primary-dark); font-weight: 600; margin-bottom: 0.75rem;">
                  {account.highlight}
                </p>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; font-size: 0.85rem; color: var(--color-text-muted);">
                  <div><strong>Min deposit:</strong> {account.minDeposit}</div>
                  <div><strong>FDIC:</strong> {account.fdic}</div>
                </div>
              </div>
              <div style="text-align: right; min-width: 130px;">
                <div style="font-size: 2rem; font-weight: 900; color: var(--color-secondary-dark);">{account.apy}</div>
                <div style="font-size: 0.75rem; color: var(--color-text-light); margin-bottom: 0.35rem;">APY</div>
                <div style="font-size: 0.85rem; font-weight: 600; color: var(--color-accent);">{account.bonus}</div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Tyler's Approach -->
      <div style="background: var(--color-bg-alt); border-radius: var(--radius-md); padding: 2rem; border: 1px solid var(--color-border);">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <img src="/proof-thinking.png" alt="Proof" style="width: 40px; height: auto;" />
          <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--color-text); margin: 0;">Why I use all three</h3>
        </div>
        <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.7; margin: 0;">
          I keep money across SoFi, Wealthfront, and Robinhood to maximize sign-up bonuses and spread FDIC coverage. The APYs are nearly identical right now, so the real difference is in bonus structures and features. Detailed reviews are coming soon as part of our Friday Savings series.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

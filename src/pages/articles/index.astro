---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Articles";
const description = "All ProofLabs articles on credit cards, cashback, savings, and financial optimization.";
---

<BaseLayout title={title} description={description}>
  <div class="container-custom" style="padding: 5rem 0 6rem;">
    <div style="max-width: 52rem; margin: 0 auto;">
      <h1 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 0.75rem; color: var(--color-text);">
        {title}
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7; margin-bottom: 3rem;">
        {description}
      </p>

      <div style="text-align: center; padding: 4rem 2rem; background: var(--color-bg-alt); border-radius: var(--radius-lg); border: 1px solid var(--color-border);">
        <img src="/proof-thinking.png" alt="Proof thinking" style="width: 80px; height: auto; margin: 0 auto 1.5rem; opacity: 0.8;" />
        <p style="font-size: 1.125rem; color: var(--color-text-muted); margin-bottom: 2rem;">
          Articles are publishing daily starting Monday, March 24, 2026.
        </p>
        <a href="/strategies" class="btn-primary">
          Read strategies while you wait
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';

// Stats removed per Tyler's request

const publishingSchedule = [
  { day: 'Monday', theme: 'Maximize Monday', category: 'Credit Cards', color: '#3b82f6', description: 'Single-card deep dives and maximization strategies' },
  { day: 'Tuesday', theme: 'Tactics Tuesday', category: 'Cashback', color: '#10b981', description: 'Multi-card stacking and workflow optimization' },
  { day: 'Wednesday', theme: 'Wealth Wednesday', category: 'Credit & Finance', color: '#8b5cf6', description: 'Credit scores, banking, and personal finance' },
  { day: 'Thursday', theme: 'Thrive Thursday', category: 'Investing', color: '#f59e0b', description: 'Building your future with smart investments' },
  { day: 'Friday', theme: 'Freedom Friday', category: 'Savings', color: '#14b8a6', description: 'High-yield savings and financial independence' },
  { day: 'Saturday', theme: 'Saturday Stories', category: 'Editorial', color: '#6b7280', description: 'Deep dives, opinion pieces, and weekly recaps' },
];

const featuredContent = [
  {
    title: 'Why I Pay $495/Year for a Credit Card',
    description: "The BILT Palladium fee sounds insane\u2014until you see the rent day multipliers and Rakuten stacking.",
    href: '/strategies/bilt-palladium-deep-dive',
    category: 'Deep Dive',
    readTime: '12 min'
  },
  {
    title: 'BILT Rent Day: The 4x Multiplier',
    description: 'On the 1st of every month, everything doubles. 2x becomes 4x, 4% becomes 8%.',
    href: '/strategies/rent-day-optimization',
    category: 'Strategy',
    readTime: '11 min'
  },
  {
    title: 'Stacking Rakuten with BILT for 17%+',
    description: "Rakuten cashback converts to BILT points. Add rent day multipliers and you're earning 17\u201325%.",
    href: '/strategies/rakuten-bilt-stacking',
    category: 'Advanced',
    readTime: '13 min'
  },
  {
    title: 'The Costco Stack: 6% on Groceries',
    description: 'Executive membership + Costco Visa = 6% total return. Plus the shop card hack.',
    href: '/strategies/costco-executive-visa-stack',
    category: 'Strategy',
    readTime: '10 min'
  },
];
---

<BaseLayout
  title="Maximize Every Dollar You Spend"
  description="Maximize cash back from the spending you already do. Real strategies for credit card stacking, cashback portals, and rewards optimization."
>
  <!-- Hero Section -->
  <section style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 4rem 0 5rem;">
      <div style="max-width: 52rem; margin: 0 auto; text-align: center;">
        <div style="margin-bottom: 1.5rem;">
          <img src="/proof-happy.png" alt="Proof the Hedgehog" style="width: 110px; height: auto; margin: 0 auto; display: block;" />
        </div>

        <h1 style="font-size: 2.75rem; font-weight: 700; margin-bottom: 1.25rem; line-height: 1.2; color: var(--color-text); letter-spacing: -0.025em;">
          Maximize cash back from the spending you already do
        </h1>

        <p style="font-size: 1.2rem; color: var(--color-text-muted); margin-bottom: 2rem; max-width: 42rem; margin-left: auto; margin-right: auto; line-height: 1.7;">
          Same purchases. Same lifestyle. Better returns. Learn how to stack credit cards and cashback portals to turn everyday spending into serious annual rewards.
        </p>

        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem;">
          <a href="/strategies/secret-sauce" class="btn-primary">
            Read my strategy
          </a>
          <a href="/strategies" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 2rem; background-color: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border); border-radius: var(--radius-full); font-weight: 600; font-size: 1rem; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.backgroundColor='var(--color-bg-alt)';" onmouseout="this.style.backgroundColor='var(--color-surface)';">
            Browse all strategies
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 6-Day Publishing Schedule -->
  <section style="background-color: var(--color-bg-alt); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 4rem 0;">
      <div style="max-width: 52rem; margin: 0 auto 2rem;">
        <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text);">
          New articles 6 days a week
        </h2>
        <p style="font-size: 1.05rem; color: var(--color-text-muted); line-height: 1.7;">
          Every day has a theme. Every article is backed by real data.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; max-width: 56rem; margin: 0 auto;">
        {publishingSchedule.map(item => (
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.5rem; text-align: center; transition: all 0.2s;" onmouseover={`this.style.borderColor='${item.color}'; this.style.transform='translateY(-2px)';`} onmouseout="this.style.borderColor='var(--color-border-light)'; this.style.transform='translateY(0)';"> 
            <div style={`width: 3rem; height: 4px; background: ${item.color}; border-radius: 2px; margin: 0 auto 1rem;`}></div>
            <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-light); margin-bottom: 0.5rem;">{item.day}</div>
            <div style={`font-size: 1.05rem; font-weight: 700; color: ${item.color}; margin-bottom: 0.5rem;`}>{item.theme}</div>
            <div style="font-size: 0.825rem; color: var(--color-text-muted); line-height: 1.5;">{item.description}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Content -->
  <section style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 4rem 0;">
      <div style="max-width: 52rem; margin: 0 auto 2rem;">
        <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text);">
          Start here
        </h2>
        <p style="font-size: 1.05rem; color: var(--color-text-muted); line-height: 1.7;">
          Real strategies from someone actually doing this. No fluff, no theory.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; max-width: 52rem; margin: 0 auto;">
        {featuredContent.map(article => (
          <a href={article.href} style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.5rem; text-decoration: none; color: inherit; transition: border-color 0.2s;" onmouseover="this.style.borderColor='#d1d5db';" onmouseout="this.style.borderColor='var(--color-border-light)';">
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
              <span style="font-size: 0.8rem; font-weight: 600; color: var(--color-secondary);">{article.category}</span>
              <span style="color: #d1d5db;">&middot;</span>
              <span style="font-size: 0.8rem; color: var(--color-text-light);">{article.readTime}</span>
            </div>
            <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem; line-height: 1.35;">
              {article.title}
            </h3>
            <p style="color: var(--color-text-muted); line-height: 1.6; font-size: 0.9rem; margin: 0;">
              {article.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Tyler's Stack -->
  <section style="background-color: var(--color-bg-alt);">
    <div class="container-custom" style="padding: 4rem 0;">
      <div style="max-width: 52rem; margin: 0 auto;">
        <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 2rem;">
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <img src="/proof-thinking.png" alt="Proof" style="width: 44px; height: auto;" />
            <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin: 0;">
              My actual card stack (2026)
            </h2>
          </div>
          <p style="font-size: 0.9375rem; color: var(--color-text-muted); margin-bottom: 1.25rem;">
            This is what I personally use. Real earnings, real strategy.
          </p>
          <div style="font-family: monospace; font-size: 0.9375rem; line-height: 2; color: var(--color-text);">
            <div>&#x1F3E0; Rent &#x2192; <strong>BILT 2.0</strong></div>
            <div>&#x1F6D2; Costco &#x2192; <strong>Costco Anywhere Visa</strong></div>
            <div>&#x1F4B3; Everything else &#x2192; <strong>BILT Palladium</strong></div>
            <div>&#x1F504; Online purchases &#x2192; <strong>Rakuten</strong></div>
          </div>
          <div style="margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid var(--color-border);">
            <a href="/strategies/secret-sauce" style="color: var(--color-secondary); text-decoration: underline; font-weight: 600;">
              Read the full breakdown &#x2192;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

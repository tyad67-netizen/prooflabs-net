---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import EmailCapture from '../components/EmailCapture.astro';

const stats = [
  { value: '2 cards', label: 'My actual stack' },
  { value: '$3,500+', label: 'Annual return' },
  { value: 'No churning', label: 'Long-term holds' },
];

const pillars = [
  {
    title: 'Credit Card Stacking',
    description: 'Combine multiple cards to maximize rewards across all spending categories',
    icon: '💳',
    href: '/strategies',
  },
  {
    title: 'High-Yield Savings',
    description: 'Earn 4-5% APY on your cash with top-rated savings accounts',
    icon: '💰',
    href: '/banking/high-yield-savings',
  },
  {
    title: 'Cash Back Portals',
    description: 'Stack Rakuten, credit cards, and browser extensions for triple rewards',
    icon: '🔄',
    href: '/strategies/cashback-stacking',
  },
  {
    title: 'Investing Platforms',
    description: 'Get sign-up bonuses and better rates with optimized brokerage accounts',
    icon: '📈',
    href: '/investing/platform-bonuses',
  },
];

const featuredContent = [
  {
    title: 'Why I Pay $500/Year for a Credit Card',
    description: "The BILT Palladium fee sounds insane—until you see the rent day multipliers, Rakuten stacking, and arbitrage plays. Here's how I turn $500 into $2,000.",
    href: '/strategies/bilt-palladium-deep-dive',
    category: 'Deep Dive',
    readTime: '12 min read'
  },
  {
    title: 'BILT Rent Day: The 4x Multiplier',
    description: 'On the 1st of every month, everything doubles. 2x becomes 4x, 4% becomes 8%. Learn how to plan your spending to capture 12% returns.',
    href: '/strategies/rent-day-optimization',
    category: 'Strategy',
    readTime: '11 min read'
  },
  {
    title: 'Stacking Rakuten with BILT for 17%+',
    description: 'Rakuten cashback converts to BILT points. Add rent day multipliers and you\'re earning 17-25% on everyday purchases.',
    href: '/strategies/rakuten-bilt-stacking',
    category: 'Advanced',
    readTime: '13 min read'
  },
  {
    title: 'The Costco Stack: 6% on Groceries',
    description: 'Executive membership + Costco Visa = 6% total return. Plus a potential shop card hack that could push it even higher.',
    href: '/strategies/costco-executive-visa-stack',
    category: 'Strategy',
    readTime: '10 min read'
  },
];
---

<BaseLayout
  title="Maximize Every Dollar You Spend"
  description="Earn $3,500+/year through credit card stacking, high-yield savings, and cashback portals. Real strategies tested on real spending."
>
  <!-- Hero Section -->
  <section style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 5rem 0 6rem;">
      <div style="max-width: 52rem; margin: 0 auto; text-align: center;">
        <h1 style="font-size: 3rem; font-weight: 700; margin-bottom: 1.5rem; line-height: 1.2; color: var(--color-text); letter-spacing: -0.025em;">
          I earn $3,500+/year with 2 credit cards and a browser extension
        </h1>
        
        <p style="font-size: 1.25rem; color: var(--color-text-muted); margin-bottom: 3rem; max-width: 44rem; margin-left: auto; margin-right: auto; line-height: 1.7;">
          Same spending. Same lifestyle. Better returns. Here's how I stack BILT Palladium, Costco Visa, and Rakuten to turn everyday purchases into thousands per year.
        </p>
        
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 4rem;">
          <a href="/strategies/secret-sauce" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 2rem; background-color: var(--color-accent); color: white; border-radius: var(--radius-sm); font-weight: 600; font-size: 1rem; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.backgroundColor='var(--color-accent-dark)';" onmouseout="this.style.backgroundColor='var(--color-accent)';">
            Read my strategy
          </a>
          <a href="/strategies/credit-card-stacking" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 2rem; background-color: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-weight: 600; font-size: 1rem; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-border)'; this.style.backgroundColor='var(--color-bg-alt)';" onmouseout="this.style.borderColor='var(--color-border)'; this.style.backgroundColor='var(--color-surface)';">
            Learn card stacking
          </a>
        </div>
        
        <!-- Stats -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem; max-width: 48rem; margin: 0 auto; padding-top: 3rem; border-top: 1px solid var(--color-border-light);">
          {stats.map((stat) => (
            <div style="text-align: center;">
              <div style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-text);">{stat.value}</div>
              <div style="font-size: 0.875rem; color: var(--color-text-muted);">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Content -->
  <section style="background-color: var(--color-bg-alt); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 5rem 0;">
      <div style="max-width: 52rem; margin: 0 auto 3rem;">
        <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text);">
          Start here
        </h2>
        <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7;">
          Real strategies from someone actually doing this. No fluff, no theory—just what works.
        </p>
      </div>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem; max-width: 72rem; margin: 0 auto;">
        {featuredContent.map(article => (
          <a href={article.href} style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); overflow: hidden; text-decoration: none; color: inherit; transition: border-color 0.2s;" onmouseover="this.style.borderColor='#d1d5db';" onmouseout="this.style.borderColor='#e5e7eb';">
            <div style="padding: 2rem;">
              <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                <span style="font-size: 0.875rem; font-weight: 600; color: var(--color-secondary);">
                  {article.category}
                </span>
                <span style="color: #d1d5db;">·</span>
                <span style="font-size: 0.875rem; color: var(--color-text-light);">
                  {article.readTime}
                </span>
              </div>
              
              <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem; line-height: 1.4;">
                {article.title}
              </h3>
              <p style="color: var(--color-text-muted); line-height: 1.6; font-size: 0.9375rem;">
                {article.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Financial Optimization Pillars -->
  <section style="background-color: var(--color-surface);">
    <div class="container-custom" style="padding: 5rem 0;">
      <div style="max-width: 52rem; margin: 0 auto 3rem;">
        <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text);">
          Four ways to maximize your money
        </h2>
        <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7;">
          Stack multiple strategies to compound your annual returns. Most people only use one—you'll use all four.
        </p>
      </div>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; max-width: 72rem; margin: 0 auto;">
        {pillars.map(pillar => (
          <a href={pillar.href} style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 2rem; text-decoration: none; color: inherit; transition: border-color 0.2s;" onmouseover="this.style.borderColor='#d1d5db';" onmouseout="this.style.borderColor='#e5e7eb';">
            <div style="font-size: 2rem; margin-bottom: 1rem;">
              {pillar.icon}
            </div>
            
            <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">
              {pillar.title}
            </h3>
            <p style="color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.6;">
              {pillar.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why This Works -->
  <section style="background-color: var(--color-bg-alt);">
    <div class="container-custom" style="padding: 5rem 0;">
      <div style="max-width: 52rem; margin: 0 auto;">
        <div style="margin-bottom: 3rem;">
          <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text);">
            Why this approach works
          </h2>
          <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7;">
            Most people leave thousands on the table by only optimizing one area. Stack all four pillars and compound your returns.
          </p>
        </div>
        
        <div style="display: grid; gap: 2rem;">
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 2rem;">
            <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">Tested on real spending</h3>
            <p style="color: var(--color-text-muted); line-height: 1.7; font-size: 0.9375rem;">Every strategy is based on actual results from my own spending patterns. I'm not recommending theory—this is what I actually do and the returns I actually see.</p>
          </div>
          
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 2rem;">
            <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">No lifestyle changes required</h3>
            <p style="color: var(--color-text-muted); line-height: 1.7; font-size: 0.9375rem;">You don't need to change what you buy or where you shop. These strategies optimize the money you're already spending—same life, better returns.</p>
          </div>
          
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 2rem;">
            <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem;">Compounds over time</h3>
            <p style="color: var(--color-text-muted); line-height: 1.7; font-size: 0.9375rem;">Small optimizations in multiple areas compound to thousands per year. Credit card cash back + HYSA interest + investing bonuses + portal rewards = real money.</p>
          </div>
        </div>

        <!-- Tyler's Stack Example -->
        <div style="margin-top: 3rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 2rem;">
          <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem;">
            My actual card stack (2026)
          </h3>
          <p style="font-size: 0.9375rem; color: var(--color-text-muted); margin-bottom: 1.5rem;">
            This is what I personally use. Proof coming soon—I'm adding screenshots from my actual statements.
          </p>
          <div style="font-family: monospace; font-size: 0.9375rem; line-height: 2; color: var(--color-text);">
            <div>🏠 Rent → <strong>BILT 2.0</strong></div>
            <div>🛒 Costco → <strong>Costco Anywhere Visa</strong></div>
            <div>💳 Everything else → <strong>BILT Palladium</strong></div>
            <div>🔄 Online purchases → <strong>Rakuten</strong></div>
          </div>
          <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
            <a href="/strategies/secret-sauce" style="color: var(--color-secondary); text-decoration: underline; font-weight: 600;">
              Read the full breakdown →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Email Capture -->
  <section style="background-color: var(--color-surface);">
    <div class="container-custom" style="padding: 5rem 0;">
      <div style="max-width: 48rem; margin: 0 auto;">
        <EmailCapture
          variant="hero"
          headline="Get Tyler's Cash Back Tracking Spreadsheet"
          description="The same Google Sheets template I use to track my $3,500+/year in rewards. Plug in your own cards and spending to see your total."
          buttonText="Send me the spreadsheet"
        />
      </div>
    </div>
  </section>
</BaseLayout>

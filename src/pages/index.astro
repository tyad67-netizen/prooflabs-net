---
import MinimalLayout from '../layouts/MinimalLayout.astro';
---

<MinimalLayout
  title="ProofLabs Links"
  description="Money optimization strategies and referral links."
>
  <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #FDF8F3 0%, #F5E6D3 100%); padding: 2rem;">
    <div style="max-width: 600px; width: 100%; background: white; border-radius: 24px; padding: 3rem 2rem; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
      
      <!-- Header -->
      <div style="text-align: center; margin-bottom: 3rem;">
        <img src="/proof-happy-clean.png" alt="ProofLabs" style="width: 100px; height: auto; margin: 0 auto 1.5rem;" />
        <h1 style="font-size: 2rem; font-weight: 800; color: #2C2420; margin-bottom: 0.5rem;">
          @TheProofLabs
        </h1>
        <p style="font-size: 1.125rem; color: #7A6F66; line-height: 1.6; margin-bottom: 0.75rem;">
          Money optimization strategies. Real math, no fluff.
        </p>
        <div style="display: inline-block; background: linear-gradient(135deg, #FFF5E6, #F5E6D3); border: 1px solid #E8913A; border-radius: 12px; padding: 0.5rem 1rem; font-size: 0.875rem; font-weight: 600; color: #D45B3F;">
          📊 Expanding Soon
        </div>
      </div>

      <!-- Links -->
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        
        <!-- Rakuten -->
        <a 
          href="https://www.rakuten.com/r/TYLERM3316?eeid=28187" 
          target="_blank" 
          rel="noopener"
          style="display: block; background: linear-gradient(135deg, #FFF5E6 0%, #F5BC6E 100%); border: 2px solid #E8913A; border-radius: 16px; padding: 1.5rem; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s;"
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(232,145,58,0.3)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';"
        >
          <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="font-size: 2rem;">💰</div>
            <div style="flex: 1;">
              <div style="font-size: 1.125rem; font-weight: 700; color: #2C2420; margin-bottom: 0.25rem;">
                Get $50 from Rakuten
              </div>
              <div style="font-size: 0.875rem; color: #7A6F66;">
                Stack cashback with your credit cards
              </div>
            </div>
            <div style="color: #E8913A; font-size: 1.25rem;">→</div>
          </div>
        </a>

        <!-- Twitter -->
        <a 
          href="https://x.com/TheProofLabs" 
          target="_blank" 
          rel="noopener"
          style="display: block; background: #F7F7F7; border: 2px solid #E5E5E5; border-radius: 16px; padding: 1.5rem; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s;"
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(0,0,0,0.1)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';"
        >
          <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="font-size: 2rem;">𝕏</div>
            <div style="flex: 1;">
              <div style="font-size: 1.125rem; font-weight: 700; color: #2C2420; margin-bottom: 0.25rem;">
                Follow on X/Twitter
              </div>
              <div style="font-size: 0.875rem; color: #7A6F66;">
                Daily money optimization threads
              </div>
            </div>
            <div style="color: #7A6F66; font-size: 1.25rem;">→</div>
          </div>
        </a>

        <!-- Email (placeholder - can add ConvertKit link later) -->
        <a 
          href="mailto:contact@prooflabs.net" 
          style="display: block; background: #F7F7F7; border: 2px solid #E5E5E5; border-radius: 16px; padding: 1.5rem; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s;"
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(0,0,0,0.1)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';"
        >
          <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="font-size: 2rem;">📬</div>
            <div style="flex: 1;">
              <div style="font-size: 1.125rem; font-weight: 700; color: #2C2420; margin-bottom: 0.25rem;">
                Get in Touch
              </div>
              <div style="font-size: 0.875rem; color: #7A6F66;">
                Questions or feedback
              </div>
            </div>
            <div style="color: #7A6F66; font-size: 1.25rem;">→</div>
          </div>
        </a>

      </div>

      <!-- Footer -->
      <div style="text-align: center; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #E5E5E5;">
        <p style="font-size: 0.875rem; color: #7A6F66;">
          © 2026 ProofLabs. Simple math beats complex strategies.
        </p>
      </div>

    </div>
  </div>
</MinimalLayout>

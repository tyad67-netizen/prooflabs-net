---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailCapture from '../components/EmailCapture.astro';
import latestArticles from '../data/latest-articles.json';

// Stats removed per Tyler's request

const dayMap = {
  'Monday': 'monday',
  'Tuesday': 'tuesday', 
  'Wednesday': 'wednesday',
  'Thursday': 'thursday',
  'Friday': 'friday',
  'Saturday': 'saturday'
};

const publishingSchedule = [
  { 
    day: 'Monday', 
    theme: 'Maximize Monday', 
    category: 'Credit Cards', 
    color: '#3b82f6', 
    description: 'Single-card deep dives and maximization strategies',
    featured: latestArticles.monday
  },
  { 
    day: 'Tuesday', 
    theme: 'Tactics Tuesday', 
    category: 'Cashback', 
    color: '#10b981', 
    description: 'Multi-card stacking and workflow optimization',
    featured: latestArticles.tuesday
  },
  { 
    day: 'Wednesday', 
    theme: 'Wealth Wednesday', 
    category: 'Credit & Finance', 
    color: '#8b5cf6', 
    description: 'Credit scores, banking, and personal finance',
    featured: latestArticles.wednesday
  },
  { 
    day: 'Thursday', 
    theme: 'Thrive Thursday', 
    category: 'Investing', 
    color: '#f59e0b', 
    description: 'Building your future with smart investments',
    featured: latestArticles.thursday
  },
  { 
    day: 'Friday', 
    theme: 'Freedom Friday', 
    category: 'Savings', 
    color: '#14b8a6', 
    description: 'High-yield savings and financial independence',
    featured: latestArticles.friday
  },
  { 
    day: 'Saturday', 
    theme: 'Saturday Stories', 
    category: 'Editorial', 
    color: '#6b7280', 
    description: 'Deep dives, opinion pieces, and weekly recaps',
    featured: latestArticles.saturday
  },
];
---

<BaseLayout
  title="Maximize Every Dollar You Spend"
  description="Maximize cash back from the spending you already do. Real strategies for credit card stacking, cashback portals, and rewards optimization."
>
  <!-- Hero Section -->
  <section style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 4rem 0 5rem;">
      <div style="max-width: 52rem; margin: 0 auto; text-align: center;">
        <div style="margin-bottom: 1.5rem;">
          <img src="/proof-happy.png" alt="Proof the Hedgehog" style="width: 110px; height: auto; margin: 0 auto; display: block;" />
        </div>

        <h1 style="font-size: 2.75rem; font-weight: 700; margin-bottom: 1.25rem; line-height: 1.2; color: var(--color-text); letter-spacing: -0.025em;">
          Maximize cash back from the spending you already do
        </h1>

        <p style="font-size: 1.2rem; color: var(--color-text-muted); margin-bottom: 2rem; max-width: 42rem; margin-left: auto; margin-right: auto; line-height: 1.7;">
          Same purchases. Same lifestyle. Better returns. Learn how to stack credit cards and cashback portals to turn everyday spending into serious annual rewards.
        </p>

        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem;">
          <a href="/strategies/secret-sauce" class="btn-primary">
            Read my strategy
          </a>
          <a href="/strategies" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.875rem 2rem; background-color: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border); border-radius: var(--radius-full); font-weight: 600; font-size: 1rem; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.backgroundColor='var(--color-bg-alt)';" onmouseout="this.style.backgroundColor='var(--color-surface)';">
            Browse all strategies
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Publishing Schedule + Start Here (Combined) -->
  <section style="background-color: var(--color-bg-alt); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 4rem 0;">
      <div style="max-width: 64rem; margin: 0 auto 3rem; text-align: center;">
        <h2 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text);">
          Start here: 6 themes, daily publishing
        </h2>
        <p style="font-size: 1.125rem; color: var(--color-text-muted); line-height: 1.7;">
          Every day has a theme. Every article is backed by real data. New content Monday–Saturday at 6 AM PST.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; max-width: 64rem; margin: 0 auto;">
        {publishingSchedule.map(item => (
          <div style={`background: var(--color-surface); border: 2px solid ${item.color}20; border-radius: var(--radius-lg); padding: 1.75rem; transition: all 0.2s;`} onmouseover={`this.style.borderColor='${item.color}'; this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 16px rgba(0,0,0,0.1)';`} onmouseout={`this.style.borderColor='${item.color}20'; this.style.transform='translateY(0)'; this.style.boxShadow='none';`}>
            
            {/* Header */}
            <div style="margin-bottom: 1.25rem;">
              <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-light); margin-bottom: 0.5rem;">{item.day}</div>
              <div style={`font-size: 1.25rem; font-weight: 700; color: ${item.color}; margin-bottom: 0.5rem;`}>{item.theme}</div>
              <div style="font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.5;">{item.description}</div>
            </div>

            {/* Featured Article or Coming Soon */}
            {item.featured ? (
              <a href={item.featured.href} style="display: block; background: var(--color-bg-alt); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1rem; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='var(--color-surface)';" onmouseout="this.style.background='var(--color-bg-alt)';">
                <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-text-light); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Featured Strategy</div>
                <div style="font-size: 0.95rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.25rem; line-height: 1.3;">{item.featured.title}</div>
                <div style="font-size: 0.75rem; color: var(--color-text-light);">{item.featured.readTime} read</div>
              </a>
            ) : (
              <div style="background: var(--color-bg-alt); border: 1px dashed var(--color-border); border-radius: var(--radius-md); padding: 1.25rem; text-align: center;">
                <div style="font-size: 0.875rem; color: var(--color-text-light);">First article publishes Monday, March 24</div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tyler's Stack -->
  <section style="background-color: var(--color-bg-alt);">
    <div class="container-custom" style="padding: 4rem 0;">
      <div style="max-width: 52rem; margin: 0 auto;">
        <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 2rem;">
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <img src="/proof-thinking.png" alt="Proof" style="width: 44px; height: auto;" />
            <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin: 0;">
              My actual card stack (2026)
            </h2>
          </div>
          <p style="font-size: 0.9375rem; color: var(--color-text-muted); margin-bottom: 1.25rem;">
            This is what I personally use. Real earnings, real strategy.
          </p>
          <div style="font-family: monospace; font-size: 0.9375rem; line-height: 2; color: var(--color-text);">
            <div>&#x1F3E0; Rent &#x2192; <strong>BILT 2.0</strong></div>
            <div>&#x1F6D2; Costco &#x2192; <strong>Costco Anywhere Visa</strong></div>
            <div>&#x1F4B3; Everything else &#x2192; <strong>BILT Palladium</strong></div>
            <div>&#x1F504; Online purchases &#x2192; <strong>Rakuten</strong></div>
          </div>
          <div style="margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid var(--color-border);">
            <a href="/strategies/secret-sauce" style="color: var(--color-secondary); text-decoration: underline; font-weight: 600;">
              Read the full breakdown &#x2192;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

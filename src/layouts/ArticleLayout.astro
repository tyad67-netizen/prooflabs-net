---
import BaseLayout from './BaseLayout.astro';
import RelatedArticles from '../components/RelatedArticles.astro';

interface RelatedArticle {
  title: string;
  url: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  lastUpdated: string;
  category?: string;
  relatedArticles?: RelatedArticle[];
}

const { title, description, lastUpdated, category = 'Strategies', relatedArticles = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <!-- Breadcrumbs -->
  <div style="background-color: var(--color-bg-alt); border-bottom: 1px solid var(--color-border-light);">
    <div class="container-custom" style="padding: 1rem 0;">
      <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--color-text-muted);">
        <a href="/" style="color: var(--color-secondary); text-decoration: none;">Home</a>
        <span>&rarr;</span>
        <a href="/strategies" style="color: var(--color-secondary); text-decoration: none;">{category}</a>
        <span>&rarr;</span>
        <span style="color: var(--color-text);">{title}</span>
      </div>
    </div>
  </div>

  <!-- Article Content -->
  <div class="container-custom" style="padding: 3rem 0 6rem;">
    <div style="max-width: 72rem; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 280px; gap: 4rem;">
        <!-- Main Content -->
        <article>
          <!-- Header -->
          <header style="margin-bottom: 2.5rem;">
            <h1 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 1rem; color: var(--color-text); line-height: 1.2;">
              {title}
            </h1>

            <div style="display: flex; align-items: center; gap: 2rem; padding: 1rem 0; border-top: 1px solid var(--color-border-light); border-bottom: 1px solid var(--color-border-light); margin-top: 1rem;">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <img src="/tyler-photo.jpg" alt="Tyler" style="width: 28px; height: 28px; border-radius: 50%; object-fit: cover;" />
                <span style="color: var(--color-text); font-size: 0.875rem; font-weight: 600;">Tyler</span>
              </div>
              <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--color-text-muted); font-size: 0.875rem;">
                <span>Updated {lastUpdated}</span>
              </div>
            </div>
          </header>

          <!-- Affiliate Disclosure Banner -->
          <div style="background: var(--color-primary-bg); border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding: 0.75rem 1rem; margin-bottom: 2rem; font-size: 0.825rem; color: var(--color-text-muted); line-height: 1.5;">
            This article may contain affiliate or referral links. If you sign up through our links, we may earn a commission at no cost to you. This does not affect our rankings. <a href="/how-we-make-money" style="color: var(--color-secondary); text-decoration: underline;">How we make money</a>
          </div>

          <!-- Article Body -->
          <div style="font-size: 1.125rem; line-height: 1.8; color: var(--color-text-muted);">
            <slot />
          </div>

          <!-- Author Bio -->
          <div style="background-color: var(--color-bg-alt); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.75rem; margin-top: 3rem;">
            <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
              <img src="/tyler-photo.jpg" alt="Tyler" style="width: 56px; height: 56px; border-radius: 50%; object-fit: cover; flex-shrink: 0;" />
              <div>
                <h4 style="font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.35rem;">Tyler, Founder of ProofLabs</h4>
                <p style="font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.6; margin: 0;">
                  Tyler earns $3,500+/year through credit card stacking, cashback portals, and referral optimization. Every strategy on this site is one he personally uses. <a href="/about" style="color: var(--color-secondary); text-decoration: underline;">Read more</a>
                </p>
              </div>
            </div>
          </div>

          <!-- Methodology Link -->
          <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border-light);">
            <p style="margin: 0; font-size: 0.825rem; color: var(--color-text-light);">
              This article follows our <a href="/methodology" style="color: var(--color-secondary); text-decoration: underline;">research methodology</a>. Rankings are based on real math, not affiliate commissions.
            </p>
          </div>

          <!-- Related Articles -->
          {relatedArticles.length > 0 && (
            <RelatedArticles articles={relatedArticles} />
          )}
        </article>

        <!-- Sidebar -->
        <aside style="position: sticky; top: 5.5rem; align-self: start;">
          <div style="background-color: var(--color-bg-alt); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.5rem;">
            <h3 style="font-size: 0.85rem; font-weight: 700; margin-bottom: 1rem; color: var(--color-text); text-transform: uppercase; letter-spacing: 0.05em;">
              On This Page
            </h3>
            <nav id="toc" style="font-size: 0.875rem;"></nav>
          </div>

          <div style="margin-top: 1.5rem; background-color: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-md); padding: 1.5rem; text-align: center;">
            <p style="font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: 0.75rem;">
              See all strategies
            </p>
            <a href="/strategies" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.625rem 1.25rem; background-color: var(--color-accent); color: white; border-radius: var(--radius-full); font-weight: 700; font-size: 0.85rem; text-decoration: none; transition: all 0.2s; width: 100%;" onmouseover="this.style.background='var(--color-accent-dark)';" onmouseout="this.style.background='var(--color-accent)';">
              Browse Strategies
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const article = document.querySelector('article');
      const toc = document.getElementById('toc');
      if (!article || !toc) return;

      const headings = article.querySelectorAll('h2, h3');
      if (headings.length === 0) return;

      const tocList = document.createElement('ul');
      tocList.style.cssText = 'list-style: none; padding: 0; margin: 0;';

      headings.forEach((heading, index) => {
        const id = `heading-${index}`;
        heading.id = id;

        const li = document.createElement('li');
        li.style.cssText = 'margin-bottom: 0.75rem;';
        if (heading.tagName === 'H3') {
          li.style.paddingLeft = '1rem';
        }

        const link = document.createElement('a');
        link.href = `#${id}`;
        link.textContent = heading.textContent;
        link.style.cssText = 'color: var(--color-text-muted); text-decoration: none; transition: color 0.2s; display: block;';
        link.onmouseover = () => link.style.color = 'var(--color-primary)';
        link.onmouseout = () => link.style.color = 'var(--color-text-muted)';

        li.appendChild(link);
        tocList.appendChild(li);
      });

      toc.appendChild(tocList);
    });
  </script>

  <style>
    @media (max-width: 1024px) {
      article {
        grid-template-columns: 1fr !important;
      }
      aside {
        display: none;
      }
    }
  </style>
</BaseLayout>
